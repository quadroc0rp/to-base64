{
  "name": "to-base64",
  "displayName": "to-base64",
  "description": "Encode files to Base64 directly from the Explorer window",
  "version": "0.2.0",
  "publisher": "quadroc0rp",
  "icon": "icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/quadroc0rp/to-base64"
  },
  "bugs": {
    "url": "https://github.com/quadroc0rp/to-base64/issues"
  },
  "homepage": "https://github.com/quadroc0rp/to-base64#readme",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "to-base64.encode",
        "title": "Encode to Base64",
        "category": "to-base64",
        "icon": "$(code)"
      },
      {
        "command": "to-base64.setCopyToClipboard",
        "title": "Set Copy to Clipboard Mode",
        "category": "to-base64"
      },
      {
        "command": "to-base64.setOutputFolder",
        "title": "Set Output Folder",
        "category": "to-base64"
      },
      {
        "command": "to-base64.setFilenameSuffix",
        "title": "Set Filename Suffix",
        "category": "to-base64"
      },
      {
        "command": "to-base64.setRemoveOriginalExtension",
        "title": "Set Remove Original Extension",
        "category": "to-base64"
      }
    ],
    "configuration": {
      "title": "2b64 (to-base64)",
      "properties": {
        "to-base64.copyToClipboard": {
          "type": "boolean",
          "default": false,
          "description": "Copy Base64 to clipboard instead of saving files (single file only)",
          "scope": "window"
        },
        "to-base64.outputFolder": {
          "type": "string",
          "default": "",
          "description": "Custom output folder for encoded files (empty = same as source). Example: './base64/'",
          "scope": "window"
        },
        "to-base64.filenameSuffix": {
          "type": "string",
          "default": ".base64",
          "description": "Suffix appended to encoded filenames. Empty string = no suffix",
          "scope": "window"
        },
        "to-base64.removeOriginalExtension": {
          "type": "boolean",
          "default": false,
          "description": "Remove original file extension when generating output filename. For example, with this enabled, 'image.png' would become 'image.base64' instead of 'image.png.base64'. Or if the suffix is empty, 'image.png' would become 'image' instead of 'image.png'.",
          "scope": "window"
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "command": "to-base64.encode",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "clean": "rimraf dist out *.vsix",
    "clean:all": "rimraf dist out node_modules *.vsix .vscode-test"
  },
  "dependencies": {
    "js-base64": "^3.7.8"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.3",
    "mocha": "^11.0.0"
  }
}